# ============================================================
# Yuki AI — Ana Environment Dosyası Örneği
# ============================================================
# Bu dosyayı kopyalayıp .env olarak yeniden adlandırın:
#   cp .env.example .env
# Sonra gerçek değerleri girin.
# ============================================================

# --- Database (Next.js için) ---
DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- TikTok (Üçüncü parti library — Live dinleme için) ---
TIKTOK_USERNAME=yuki_xaivar
TIKTOK_SESSION_ID=your_tiktok_session_id_here

# --- TikTok Developer API (Resmi — OAuth + Display API) ---
# https://developers.tiktok.com/ app oluşturduktan sonra alın
TIKTOK_CLIENT_KEY=aw_your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_REDIRECT_URI=https://yukiai.space-z.ai/api/tiktok/callback

# --- Google Gemini (LLM) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# --- ElevenLabs (TTS) ---
# https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id

# --- OBS WebSocket ---
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=your_obs_password

# --- Bridge (Next.js mini-service) ---
BRIDGE_URL=http://localhost:3003

# --- Karakter ---
CHARACTER_NAME=Yuki
