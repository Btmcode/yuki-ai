// AI TikTok Streamer — Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StreamSession {
  id           String   @id @default(cuid())
  tiktokUser   String
  status       String   @default("idle") // idle | live | paused | ended
  startTime    DateTime?
  endTime      DateTime?
  peakViewers  Int      @default(0)
  totalGifts   Int      @default(0)
  totalDiamonds Int     @default(0)
  autonomyMode String   @default("semi") // manual | semi | full
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages     ChatMessage[]
  gifts        Gift[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String?
  username   String
  content    String
  source     String   @default("user") // user | ai | system
  status     String   @default("auto") // pending | approved | rejected | auto | sent
  aiResponse String?  // AI proposed response (when source=user)
  mood       String?  // happy | flirty | shy | excited | calm | angry
  timestamp  DateTime @default(now())

  session    StreamSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([timestamp])
}

model Gift {
  id           String   @id @default(cuid())
  sessionId    String?
  username     String
  giftName     String
  giftCount    Int      @default(1)
  diamondCount Int      @default(0)
  imageUrl     String?
  timestamp    DateTime @default(now())

  session      StreamSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([timestamp])
}

model BannedUser {
  id        String   @id @default(cuid())
  username  String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model FilteredWord {
  id        String   @id @default(cuid())
  word      String   @unique
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// TikTok OAuth — resmi TikTok Developer API entegrasyonu
// Login Kit + Display API v2 için
model TikTokAccount {
  id              String   @id @default(cuid())
  openId          String   @unique // TikTok kullanıcının unique ID'si
  username        String?  // @yuki_xaivar
  displayName     String?
  avatarUrl       String?
  bioDescription  String?
  isVerified      Boolean  @default(false)

  // OAuth tokens (şifreli saklanmalı — production'da encrypt et)
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime
  tokenType       String   @default("Bearer")
  scope           String   // "user.info.profile,user.info.stats,video.list"

  // Stats (Display API'den çekilir)
  followerCount   Int      @default(0)
  followingCount  Int      @default(0)
  likesCount      Int      @default(0)
  videoCount      Int      @default(0)
  statsUpdatedAt  DateTime?

  // Meta
  isActive        Boolean  @default(true) // aktif bağlı hesap
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  videos          TikTokVideo[]
}

model TikTokVideo {
  id              String   @id @default(cuid())
  accountId       String
  videoId         String   @unique // TikTok video ID
  title           String?
  description     String?
  coverImageUrl   String?
  shareUrl        String?
  duration        Int? // saniye
  createTime      DateTime?

  // Stats
  viewCount       Int      @default(0)
  likeCount       Int      @default(0)
  commentCount    Int      @default(0)
  shareCount      Int      @default(0)

  // Meta
  fetchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         TikTokAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([createTime])
}

