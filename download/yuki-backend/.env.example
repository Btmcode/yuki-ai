# =============================================================================
# Yuki AI — Backend Environment
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin
# =============================================================================

# --- TikTok ---
# Hesabın session ID'si (browser developer tools > Application > Cookies > sessionid)
TIKTOK_USERNAME=yuki_ai
TIKTOK_SESSION_ID=your_session_id_here

# --- Google Gemini (LLM) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# --- ElevenLabs (TTS) ---
# https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id

# --- OBS WebSocket ---
# OBS Studio > Tools > WebSocket Server Settings
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=your_obs_password

# --- Bridge (Next.js mini-service) ---
BRIDGE_URL=http://localhost:3003

# --- Karakter ---
CHARACTER_NAME=Yuki
